# ==================================================
# Other Services
# ==================================================

# YouTube Data API
# 발급: https://console.cloud.google.com/apis/credentials
YOUTUBE_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Notion API
# 발급: https://www.notion.so/my-integrations
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_WORKSPACE_PAGE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ==================================================
# Gmail API (미회신 메일 체크 - /start-day 루틴)
# ==================================================

# Gmail OAuth 인증 파일 경로
# 설정 방법: .claude/skills/start-day/scripts/SETUP-GMAIL.md 참조
GMAIL_CREDENTIALS_PATH=~/.config/gmail-claude/credentials.json

# ==================================================
# Buffer API (SNS 자동 포스팅)
# ==================================================

# ==================================================
# SNS 카드뉴스 자동화 (GPT 대화 → Canva 카드뉴스 초안)
# ==================================================

# Canva Connect API (Enterprise) — Developer Portal에서 발급
# https://www.canva.com/developers/
CANVA_CLIENT_ID=xxxxxxxxxxxxxxxx
CANVA_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# 최초 1회: python3 00-system/02-scripts/canva_autofill.py auth  실행 후 자동 기록됨
CANVA_REFRESH_TOKEN=
# 카드뉴스용 브랜드 템플릿 ID (Canva에서 데이터 필드 지정 후 ID 복사)
CANVA_BRAND_TEMPLATE_ID=

# Google Drive 폴더 ID (SNS_Automation/input · output)
SNS_DRIVE_INPUT_FOLDER_ID=
SNS_DRIVE_OUTPUT_FOLDER_ID=

# 결과 기록용 Google Sheet ID (시트 탭 이름: 카드뉴스)
SNS_SHEET_ID=

# 커스텀GPT Action ↔ Apps Script 웹훅 공유시크릿 (양쪽 동일 값)
SNS_WEBHOOK_SECRET=change-me-to-a-long-random-string

# Buffer API Token (GraphQL)
# 발급: https://publish.buffer.com/settings/api
BUFFER_API_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Buffer Channel ID (Instagram @rxr_workroom)
BUFFER_CHANNEL_ID=69e44bb9031bfa423c1c71a5

