<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  Basket 운영 일일보고 봇 — launchd 상시가동
  설치:
    cp 00-system/02-scripts/com.basket.ops-bot.plist ~/Library/LaunchAgents/
    launchctl load ~/Library/LaunchAgents/com.basket.ops-bot.plist
  (먼저 .env에 BASKET_BOT_TOKEN 등 채울 것)
-->
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.basket.ops-bot</string>
    <key>ProgramArguments</key>
    <array>
        <string>/Users/choi_ai/do-better-workspace/20-operations/24-second-brain/.venv311/bin/python</string>
        <string>-u</string>
        <string>/Users/choi_ai/do-better-workspace/00-system/02-scripts/basket-ops-bot.py</string>
    </array>
    <key>WorkingDirectory</key>
    <string>/Users/choi_ai/do-better-workspace</string>
    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/Users/choi_ai/.npm-global/bin:/Users/choi_ai/.local/bin:/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin</string>
    </dict>
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>
    <key>StandardOutPath</key>
    <string>/tmp/basket-ops-bot.log</string>
    <key>StandardErrorPath</key>
    <string>/tmp/basket-ops-bot.log</string>
</dict>
</plist>
